    <script>
        let currentStep = 1;
        const totalSteps = 5;
        const userResponses = {};

        function updateProgressIndicator() {
            const dots = document.querySelectorAll('.progress-dot');
            dots.forEach((dot, index) => {
                dot.classList.remove('active', 'completed');
                if (index + 1 === currentStep) {
                    dot.classList.add('active');
                } else if (index + 1 < currentStep) {
                    dot.classList.add('completed');
                }
            });
        }

        function showStep(stepNumber) {
            document.querySelectorAll('.step').forEach(step => {
                step.classList.remove('active');
            });
            document.getElementById(`step${stepNumber}`).classList.add('active');
            updateProgressIndicator();
        }

        function nextStep() {
            if (currentStep < totalSteps) {
                currentStep++;
                showStep(currentStep);
            }
        }

        function prevStep() {
            if (currentStep > 1) {
                currentStep--;
                showStep(currentStep);
            }
        }

        function selectOption(element, category, value) {
            // Remove selection from siblings
            const parent = element.parentElement;
            parent.querySelectorAll('.quiz-option').forEach(opt => {
                opt.classList.remove('selected');
            });

            // Add selection to clicked option
            element.classList.add('selected');

            // Store response
            userResponses[category] = value;
        }

        function validateStep2() {
            const required = ['experience', 'domain', 'goal'];
            const missing = required.filter(field => !userResponses[field]);

            if (missing.length > 0) {
                alert('請回答所有問題以繼續');
                return false;
            }
            return true;
        }

        function validateStep3() {
            const projectName = document.getElementById('projectName').value.trim();
            const projectDescription = document.getElementById('projectDescription').value.trim();

            if (!projectName || !projectDescription) {
                alert('請填寫專案名稱和描述');
                return false;
            }

            userResponses.projectName = projectName;
            userResponses.projectDescription = projectDescription;
            userResponses.currentPhase = document.getElementById('currentPhase').value;
            userResponses.techStack = document.getElementById('techStack').value;
            userResponses.githubRepo = document.getElementById('githubRepo').value;

            return true;
        }

        function validateStep4() {
            userResponses.primaryGoal = document.getElementById('primaryGoal').value;
            userResponses.timeframe = document.getElementById('timeframe').value;
            userResponses.additionalGoals = document.getElementById('additionalGoals').value;

            if (!userResponses.primaryGoal) {
                alert('請選擇主要目標');
                return false;
            }

            return true;
        }

        function completeOnboarding() {
            // Validate current step
            if (currentStep === 2 && !validateStep2()) return;
            if (currentStep === 3 && !validateStep3()) return;
            if (currentStep === 4 && !validateStep4()) return;

            // Save user responses
            localStorage.setItem('userOnboardingData', JSON.stringify(userResponses));

            // Generate personalized results
            generatePersonalizedResults();

            // Move to results step
            currentStep = 5;
            showStep(currentStep);
        }

        function generatePersonalizedResults() {
            // Display user profile
            const profileHTML = `
                <div class="result-item">
                    <span class="result-label">經驗水準</span>
                    <span class="result-value">${getExperienceLabel(userResponses.experience)}</span>
                </div>
                <div class="result-item">
                    <span class="result-label">專業領域</span>
                    <span class="result-value">${getDomainLabel(userResponses.domain)}</span>
                </div>
                <div class="result-item">
                    <span class="result-label">主要目標</span>
                    <span class="result-value">${getGoalLabel(userResponses.goal)}</span>
                </div>
                <div class="result-item">
                    <span class="result-label">專案</span>
                    <span class="result-value">${userResponses.projectName || '尚未設置'}</span>
                </div>
            `;
            document.getElementById('userProfileResults').innerHTML = profileHTML;

            // Generate personalized recommendations
            const recommendations = generateRecommendations();
            const recommendationsHTML = recommendations.map(rec => `<li>${rec}</li>`).join('');
            document.getElementById('personalizedRecommendations').innerHTML = recommendationsHTML;

            // Generate learning path
            const learningPath = generateLearningPath();
            const learningPathHTML = learningPath.map((step, index) => `
                <div class="result-item">
                    <span class="result-label">步驟 ${index + 1}</span>
                    <span class="result-value">${step}</span>
                </div>
            `).join('');
            document.getElementById('learningPathResults').innerHTML = learningPathHTML;

            // Update skills tracker with user level
            if (window.skillsTracker) {
                skillsTracker.userLevel = userResponses.experience || 'intermediate';
                skillsTracker.saveProgress();
            }
        }

        function getExperienceLabel(level) {
            const labels = {
                'beginner': '🌱 新手',
                'intermediate': '🌿 中級',
                'advanced': '🌳 高級'
            };
            return labels[level] || level;
        }

        function getDomainLabel(domain) {
            const labels = {
                'frontend': '💻 前端開發',
                'backend': '⚙️ 後端開發',
                'fullstack': '🔧 全端開發',
                'other': '🎯 其他領域'
            };
            return labels[domain] || domain;
        }

        function getGoalLabel(goal) {
            const labels = {
                'learning': '📚 學習新技能',
                'productivity': '⚡ 提高效率',
                'management': '👥 專案管理',
                'startup': '🚀 創業項目'
            };
            return labels[goal] || goal;
        }

        function generateRecommendations() {
            const recommendations = [];
            const level = userResponses.experience || 'intermediate';
            const domain = userResponses.domain || 'fullstack';

            // Level-based recommendations
            if (level === 'beginner') {
                recommendations.push('從基礎的 brainstorming skill 開始');
                recommendations.push('優先使用標準化模板確保專案結構');
                recommendations.push('參考 YC 的構思考慮模式');
            } else if (level === 'advanced') {
                recommendations.push('可以直接使用進階的並行處理功能');
                recommendations.push('建立自己的技能模板和最佳實踐');
                recommendations.push('整合 GitHub 和 CI/CD 流程');
            } else {
                recommendations.push('平衡使用基礎和進階功能');
                recommendations.push('專注於建立標準化的工作流程');
            }

            // Domain-based recommendations
            if (domain === 'frontend') {
                recommendations.push('特別關注 UX/UI 設計相關技能');
            } else if (domain === 'backend') {
                recommendations.push('重視系統架構和資料庫設計');
            }

            return recommendations.slice(0, 5); // Max 5 recommendations
        }

        function generateLearningPath() {
            const level = userResponses.experience || 'intermediate';
            const goal = userResponses.primaryGoal || 'mvp';

            const paths = {
                'beginner': [
                    '學習使用 brainstorming 進行專案構思',
                    '掌握標準化的專案規劃流程',
                    '開始第一個小功能的 TDD 開發',
                    '學習基本的除錯和測試方法'
                ],
                'intermediate': [
                    '優化 brainstorming 產出，制定詳細計畫',
                    '實作功能並建立測試覆蓋',
                    '使用 systematic debugging 處理問題',
                    '整合進度追蹤和版本控制'
                ],
                'advanced': [
                    '並行處理多個開發任務',
                    '建立自動化測試和部署流程',
                    '使用進階的 AI 輔助功能',
                    '優化開發流程和團隊協作'
                ]
            };

            return paths[level] || paths['intermediate'];
        }

        function goToDashboard() {
            // Redirect to main dashboard
            window.location.href = 'skills-assistant-dashboard.html';
        }

        // Initialize on page load
        document.addEventListener('DOMContentLoaded', () => {
            console.log('🎯 Onboarding loaded');

            // Check if user already completed onboarding
            const savedData = localStorage.getItem('userOnboardingData');
            if (savedData) {
                const data = JSON.parse(savedData);
                if (data.projectName) {
                    console.log('✅ User already completed onboarding');
                    // Could auto-redirect or offer option to skip
                }
            }
        });
    </script>
